---
import CardProject from "./CardProject.astro"
import SectionTitle from "./SectionTitle.astro";
import { technologiesMuseon } from "../lib/technologies.astro";
import { technologiesEsland } from "../lib/technologies.astro";
import { technologiesWordle } from "../lib/technologies.astro";
---

<div id="proyectos" class="w-full bg-[#151a36] shadow-inner shadow-white/20 pb-10 relative overflow-hidden">
    <div class="absolute top-32 -right-32 w-96 h-96 bg-cyan-500/10 rounded-full blur-3xl pointer-events-none" aria-hidden="true"></div>
    <div class="absolute bottom-10 -left-32 w-96 h-96 bg-blue-600/10 rounded-full blur-3xl pointer-events-none" aria-hidden="true"></div>

    <SectionTitle eyebrow="Lo que he construido" title="Mis Proyectos" />
    <section class="max-w-[1150px] 2xl:max-w-[1500px] mx-auto grid grid-cols-1 md:grid-cols-2 rx:grid-cols-3 gap-y-10 2xl:gap-y-16 relative">
        <div class="flex justify-center items-center">
        <CardProject 
            title="Esland Web" 
            image="/esland_web.png"
            content="Recreación de la página web de los Premios ESLAND mejorando su estilo y funcionalidad."
            tecnologias={technologiesEsland}
            github="https://github.com/UrielJolodovsky/esland-web"
            website="https://esland-web-urieljolo.vercel.app"
        /> 
        </div>
        <div class="flex justify-center items-center">
        <CardProject 
            title="MuseON" 
            image="/museon_logo.png"
            content="Plataforma web que ofrece recorridos virtuales por museos en la que me encargué del Backend y conexión con el Frontend de la página."
            tecnologias={technologiesMuseon}
            github="https://github.com/UrielJolodovsky/museon"
            website="https://museon-proyecto.vercel.app"
        /> 
        </div>
        <div class="flex justify-center items-center">
        <CardProject 
            title="Wordle" 
            image="/wordle_logo.png"
            content="Recreación del clásico juego digital Wordle para practicar el uso de Next.js, React y Typescript."
            tecnologias={technologiesWordle}
            github="https://github.com/UrielJolodovsky/wordle"
            website="https://wordle-urieljolo.vercel.app"
        /> 
        </div>
    </section>
</div>