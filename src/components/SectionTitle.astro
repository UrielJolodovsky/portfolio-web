---
interface Props {
    eyebrow?: string;
    title: string;
    class?: string;
}
const { eyebrow, title, class: className = "" } = Astro.props;
---

<div class:list={["text-center pt-12 pb-8 px-4", className]}>
    {
        eyebrow && (
            <p class="inline-flex items-center gap-2 text-cyan-300 text-xs sm:text-sm uppercase tracking-[0.25em] font-semibold mb-3">
                <span
                    class="w-1.5 h-1.5 rounded-full bg-cyan-400 shadow-[0_0_10px_rgba(34,211,238,0.8)] animate-pulse"
                    aria-hidden="true"
                />
                {eyebrow}
                <span
                    class="w-1.5 h-1.5 rounded-full bg-cyan-400 shadow-[0_0_10px_rgba(34,211,238,0.8)] animate-pulse"
                    aria-hidden="true"
                />
            </p>
        )
    }
    <h2 class="font-bold text-3xl sm:text-4xl lg:text-5xl text-white tracking-tight">
        {title}
    </h2>
    <div
        class="w-24 h-1 bg-gradient-to-r from-cyan-400 via-blue-400 to-blue-600 mx-auto rounded-full mt-5 shadow-[0_0_20px_rgba(34,211,238,0.5)]"
        aria-hidden="true"
    >
    </div>
</div>
