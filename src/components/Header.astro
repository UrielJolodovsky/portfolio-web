---
const links = [
    { href: "#about-me", label: "Sobre mí" },
    { href: "#experiencia", label: "Experiencia" },
    { href: "#proyectos", label: "Proyectos" },
    { href: "#otros-intereses", label: "Otros intereses" },
    { href: "#contacto", label: "Contacto" },
];
---

<div class="fixed top-5 h-auto flex justify-center items-center w-full z-50 px-4">
    <!-- Desktop nav -->
    <nav class="hidden sm:flex rounded-full bg-black/60 px-3 py-1.5 justify-center items-center shadow-md shadow-white/10 backdrop-blur-md border border-white/10">
        {
            links.map((l) => (
                <a
                    href={l.href}
                    class="hover:bg-white/10 rounded-full px-3 py-1 hover:cursor-pointer transition hover:scale-110 text-xs sm:text-base"
                >
                    {l.label}
                </a>
            ))
        }
    </nav>

    <!-- Mobile bar -->
    <div class="sm:hidden w-full flex justify-end">
        <button
            id="menu-toggle"
            type="button"
            aria-label="Abrir menú"
            aria-expanded="false"
            aria-controls="mobile-menu"
            class="rounded-full bg-black/60 backdrop-blur-md border border-white/10 shadow-md shadow-white/10 p-2.5 hover:bg-white/10 transition active:scale-95"
        >
            <svg id="icon-open" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-white">
                <line x1="4" y1="7" x2="20" y2="7" />
                <line x1="4" y1="12" x2="20" y2="12" />
                <line x1="4" y1="17" x2="20" y2="17" />
            </svg>
            <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-white hidden">
                <line x1="6" y1="6" x2="18" y2="18" />
                <line x1="6" y1="18" x2="18" y2="6" />
            </svg>
        </button>
    </div>
</div>

<!-- Mobile dropdown overlay -->
<div
    id="mobile-menu"
    class="fixed inset-0 z-40 sm:hidden hidden bg-[#0a0e1f]/95 backdrop-blur-lg flex-col items-center justify-center gap-2"
>
    {
        links.map((l) => (
            <a
                href={l.href}
                data-mobile-link
                class="text-2xl font-semibold text-white/90 hover:text-cyan-300 px-6 py-3 rounded-full hover:bg-white/5 transition-all"
            >
                {l.label}
            </a>
        ))
    }
</div>

<script>
    const toggle = document.getElementById("menu-toggle");
    const menu = document.getElementById("mobile-menu");
    const open = document.getElementById("icon-open");
    const close = document.getElementById("icon-close");

    function setOpen(isOpen: boolean) {
        if (!menu || !toggle || !open || !close) return;
        toggle.setAttribute("aria-expanded", String(isOpen));
        if (isOpen) {
            menu.classList.remove("hidden");
            menu.classList.add("flex");
            open.classList.add("hidden");
            close.classList.remove("hidden");
            document.body.style.overflow = "hidden";
        } else {
            menu.classList.add("hidden");
            menu.classList.remove("flex");
            open.classList.remove("hidden");
            close.classList.add("hidden");
            document.body.style.overflow = "";
        }
    }

    toggle?.addEventListener("click", () => {
        const isOpen = toggle.getAttribute("aria-expanded") === "true";
        setOpen(!isOpen);
    });

    document.querySelectorAll("[data-mobile-link]").forEach((el) => {
        el.addEventListener("click", () => setOpen(false));
    });

    document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") setOpen(false);
    });
</script>
