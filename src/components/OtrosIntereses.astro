---
import InteresesCard from "./InteresesCard.astro"
import SectionTitle from "./SectionTitle.astro";
---

<div id="otros-intereses" class="w-screen h-full bg-[#0d1226] shadow-inner shadow-white/10 relative overflow-hidden">
    <div class="section-divider absolute top-0 left-0 right-0" aria-hidden="true"></div>
    <div class="absolute top-20 left-1/4 w-96 h-96 bg-indigo-500/20 rounded-full blur-3xl pointer-events-none" aria-hidden="true"></div>
    <div class="absolute bottom-20 right-1/4 w-96 h-96 bg-cyan-500/15 rounded-full blur-3xl pointer-events-none" aria-hidden="true"></div>

    <SectionTitle eyebrow="Más allá del código" title="Otros intereses" accent="indigo" />
     <section class="w-full max-w-[1400px] grid grid-cols-10 auto-rows-[35rem] gap-4 mx-auto md:px-20 md:pb-20 px-5 pb-10 pt-4 relative">
        <InteresesCard class="col-span-10 sm:col-span-4" title="Matemáticas" subtitle="OMA: Olimpiada Matemática Argentina" href="matematicas">
            <div slot="image" class="absolute left-0 top-0 bottom-0 w-full h-full
            group-hover:scale-110 duration-1000 ease-in-out opacity-90
             bg-cover bg-no-repeat -z-10" style="background-image: url('/matematica.jpg')" />
        </InteresesCard>
        <InteresesCard class="col-span-10 sm:col-span-6" title="Escuela ORT" subtitle="TIC: Tecnología de la Información y Comunicaciones" href="ort">
            <div slot="image" class="absolute left-0 top-0 bottom-0 w-full h-full
            group-hover:scale-110 duration-1000 ease-in-out opacity-90
             bg-cover bg-center bg-no-repeat -z-10" style="background-image: url('/sede-belgrano.jpg')" />
        </InteresesCard>
        <InteresesCard class="col-span-10" title="Bet Hilel" subtitle="Comunidad Judía - Curso de líderes" href="bet-hilel">
            <div slot="image" class="absolute left-0 top-0 bottom-0 w-full h-full
            group-hover:scale-110 duration-1000 ease-in-out opacity-90
             bg-cover bg-center bg-no-repeat -z-10" style="background-image: url('/bet-hilel.jpg')" />
        </InteresesCard>
     </section>
</div>